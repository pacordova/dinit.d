# The ConnMan connection manager.
# Note: no network is called by default in boot.
# Use `dinitctl enable` to enable it.
# May want to consider dbus-launch for readiness notification.

type = process
command = /bin/connmand -c /etc/connman.conf -n --noplugin=vpn
smooth-recovery = true

depends-on: messagebus
waits-for: wpa_supplicant
